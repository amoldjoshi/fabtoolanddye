<%= simple_form_for(@service) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :title %>
    <%= f.input :summary %>
    <%= f.input :content %>
    <%= f.input :slug %>
    <%= f.input :image_filename,
                label: "Image filename (e.g. service-tailoring.jpg)",
                hint: "File must already exist in app/assets/images/" %>
  </div>

  <% if f.object.image_filename.present? %>
    <div class="mb-3">
      <p class="mb-1">Current image:</p>
      <%= image_tag f.object.image_filename, class: "img-thumbnail", style: "max-height: 150px;" %>
    </div>
  <% end %>

  <div class="form-actions">
    <%= f.button :submit %>
  </div>
<% end %>
