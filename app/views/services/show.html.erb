<p style="color: green"><%= notice %></p>

<div class="container py-4">

  <h1 class="mb-2"><%= @service.title %></h1>


  <hr class="my-4">

  <div class="row justify-content-center align-items-start g-5">

    <div class="col-lg-6">
      <% if @service.summary.present? %>
        <p class="lead text-muted"><%= @service.summary %></p>
      <% end %>

      <div class="fs-5" style="white-space: pre-line;"><%= @service.content %></div>

    </div>

    <div class="col-lg-6">
      <% if @service.image_filename.present? %>
        <%= image_tag @service.image_filename, class: "img-fluid rounded shadow-sm w-100" %>
      <% end %>
    </div>

  </div>

  <div class="d-flex gap-2 mt-5">
    <%= link_to "Back to Services", services_path, class: "btn btn-outline-secondary" %>

    <% if can? :edit, @service %>
      <%= link_to "Edit", edit_service_path(@service), class: "btn btn-primary" %>
    <% end %>

    <% if can? :destroy, @service %>
      <%= button_to "Delete", @service, method: :delete, class: "btn btn-outline-danger ms-auto", form: { data: { turbo_confirm: "Are you sure?" } } %>
    <% end %>
  </div>

</div>