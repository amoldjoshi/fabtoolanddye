<div class="container py-4">
  <div class="row align-items-start">

    <div class="col-lg-7 col-md-6">
      <h1><%= @page.title1 %></h1>
      <div class="fs-5" style="white-space: pre-line;"><%= @page.body1 %></div>

      <h1 class="mt-4"><%= @page.title2 %></h1>
      <div class="fs-5" style="white-space: pre-line;"><%= @page.body2 %></div>

      <% if can? :update, @page %>
        <%= link_to "Edit this page", edit_page_content_path(@page), class: "d-grid btn btn-primary btn-lg mt-4" %>
      <% end %>
    </div>

    <div class="col-lg-5 col-md-6">
      <% if @page.image_filename.present? %>
        <%= image_tag @page.image_filename, class: "img-fluid rounded shadow-sm w-100" %>
      <% end %>
    </div>

  </div>
</div>
