<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-10"> <!-- Widened container to accommodate two columns comfortably -->
      
      <div class="row align-items-start">
        
        <!-- Left Column: Wording & Content -->
        <div class="col-md-6 order-2 order-md-1">
          <h1><%= @page.title1 %></h1>
          <div class="fs-5 mb-4" style="white-space: pre-line;"><%= @page.body1 %></div>
          
          <h1><%= @page.title2 %></h1>
          <div class="fs-5 mb-4" style="white-space: pre-line;"><%= @page.body2 %></div>
          
          <% if can? :update, @page %>
            <%= link_to "Edit this page", edit_page_content_path(@page), class: "d-grid btn btn-primary btn-lg mt-4" %>
          <% end %>
        </div>
        
        <!-- Right Column: Map Image -->
        <div class="col-md-6 order-1 order-md-2 mb-4 mb-md-0">
          <% if @page.image_filename.present? %>
            <%= image_tag @page.image_filename, class: "img-fluid rounded shadow-sm w-100" %>
          <% end %>
        </div>
        
      </div>

    </div>
  </div>
</div>
