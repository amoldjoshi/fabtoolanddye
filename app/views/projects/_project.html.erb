<div id="<%= dom_id project %>">
  <% if project.image_filename.present? %>
    <div>
      <%= image_tag project.image_filename, class: "img-fluid mb-3" %>
    </div>
  <% end %>

  <div>
    <strong>Title:</strong>
    <%= project.title %>
  </div>

  <div>
    <strong>Customer:</strong>
    <%= project.customer %>
  </div>

  <div>
    <strong>Description:</strong>
    <%= project.description %>
  </div>

  <div>
    <strong>Project data:</strong>
    <%= project.project_data %>
  </div>

  <div>
    <strong>Service:</strong>
    <%= project.service_id %>
  </div>

</div>
