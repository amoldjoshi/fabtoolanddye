<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <%= simple_form_for(@project) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <%= f.input :title %>
          <%= f.input :slug,
                      hint: "Optional — auto-generated from the title if left blank" %>
          <%= f.input :customer %>
          <%= f.input :description %>
          <%= f.input :project_data %>
          <%= f.association :service %>
          <%= f.input :image_filename,
                      label: "Image filename (e.g. project-cover.jpg)",
                      hint: "File must already exist in app/assets/images/" %>
        </div>

        <% if f.object.image_filename.present? %>
          <div class="mb-3">
            <p class="mb-1">Current image:</p>
            <%= image_tag f.object.image_filename, class: "img-thumbnail", style: "max-height: 150px;" %>
          </div>
        <% end %>

        <div class="form-actions">
          <%= f.button :submit, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>