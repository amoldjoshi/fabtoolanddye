<p style="color: green"><%= notice %></p>

<div class="container py-4">

  <h1 class="mb-2"><%= @blog.title %></h1>

  <% if @blog.published_at.present? %>
    <p class="lead text-muted"><%= @blog.published_at.strftime("%B %d, %Y") %></p>
  <% end %>

  <hr class="my-4">

  <div class="row justify-content-center align-items-start g-5">

    <div class="col-lg-6">
      <% if @blog.image_filename.present? %>
        <%= image_tag @blog.image_filename, class: "img-fluid rounded shadow-sm w-100" %>
      <% end %>
    </div>

    <div class="col-lg-6">

      <% if @blog.headingone.present? %>
        <h2 class="mb-2"><%= @blog.headingone %></h2>
      <% end %>
      <div class="fs-5" style="white-space: pre-line;"><%= @blog.bodyone %></div>

      <% if @blog.headingtwo.present? %>
        <h2 class="mb-2 mt-4"><%= @blog.headingtwo %></h2>
      <% end %>
      <div class="fs-5"