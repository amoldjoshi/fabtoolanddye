<p style="color: green"><%= notice %></p>

<%= render @blog %>

<div>
  <% if can? :edit, @blog %>
    <%= link_to "Edit this blog", edit_blog_path(@blog) %> |
  <% end %>

  <%= link_to "Back to blogs", blogs_path %>

  <% if can? :destroy, @blog %>
    <%= button_to "Destroy this blog", @blog, method: :delete %>
  <% end %>
</div>
