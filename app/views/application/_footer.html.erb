<footer class="bg-dark text-white py-5 border-top fs-5">
  <div class="container">
    <div class="row gy-5">

      <!-- Logo column -->
      <div class="col-md-3 col-sm-6">
        <%= image_tag "logo.jpg", alt: "My Company", height: "240", class: "rounded" %>
      </div>

      <!-- Quick Links column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Quick Link</h4>
        <ul class="list-unstyled">
          <li class="mb-3">
            <%= link_to root_path, class: "text-white text-decoration-none" do %>
              <span class="text-white me-2">&bull;</span>Home
            <% end %>
          </li>
          <li class="mb-3">
            <%= link_to aboutus_path, class: "text-white text-decoration-none" do %>
              <span class="text-white me-2">&bull;</span>About Us
            <% end %>
          </li>
          <li class="mb-3">
            <%= link_to projects_path, class: "text-white text-decoration-none" do %>
              <span class="text-white me-2">&bull;</span>Projects
            <% end %>
          </li>
          <li class="mb-3">
            <%= link_to blogs_path, class: "text-white text-decoration-none" do %>
              <span class="text-white me-2">&bull;</span>Blogs
            <% end %>
          </li>
        </ul>
      </div>

      <!-- Our Services column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Our Services</h4>
        <ul class="list-unstyled">
          <% [
               ["Die Shop", service_path("Die_Shop")],
               ["Die Repair", "#"],
               ["CNC Machining", "#"],
               ["Aluminum Extrusion", "#"],
               ["WaterJet Cutting", "#"],
               ["PE Services", service_path("PE_Services")],
               ["Prototype & Patents", service_path("Prototype_and_Patents")],
             ].each do |label, url| %>
            <li class="mb-3">
              <%= link_to url, class: "text-white text-decoration-none" do %>
                <span class="text-white me-2">&bull;</span><%= label %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Contact column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Contact Now</h4>

        <p class="fw-bold mb-1"><span class="text-white me-2">&bull;</span>Mailing Address</p>
        <p class="mb-3 ms-3">1640 El Greco Drive, El Monte, CA 91731</p>

        <p class="fw-bold mb-1"><span class="text-white me-2">&bull;</span>Contact Number</p>
        <p class="mb-3 ms-3">+1 (909) 320-5412</p>

        <p class="fw-bold mb-1"><span class="text-white me-2">&bull;</span>Contact Email</p>
        <p class="mb-3 ms-3">ContactFabToolAndDie@gmail.com</p>

      </div>

    </div>
  </div>
</footer>