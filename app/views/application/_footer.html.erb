<footer class="bg-light text-dark py-5 border-top">
  <div class="container">
    <div class="row gy-5">

      <!-- Logo column -->
      <div class="col-md-3 col-sm-6">
        <%= image_tag "logo.png", alt: "My Company", height: "240", class: "rounded" %>
      </div>

      <!-- Quick Links column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Quick Link</h4>
        <ul class="list-unstyled">
          <li class="mb-3">
            <%= link_to root_path, class: "text-dark text-decoration-none" do %>
              <span class="text-danger me-2">&rarr;</span>Home
            <% end %>
          </li>
          <li class="mb-3">
            <%= link_to aboutus_path, class: "text-dark text-decoration-none" do %>
              <span class="text-danger me-2">&rarr;</span>About Us
            <% end %>
          </li>
        </ul>
      </div>

      <!-- Our Services column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Our Services</h4>
        <ul class="list-unstyled">
          <% [
               ["Job Shop", "#"],
               ["Lamp & Lighting Parts", "#"],
               ["Metal Fabrication", "#"],
               ["Tool & Die Maintenance", "#"]
             ].each do |label, url| %>
            <li class="mb-3">
              <%= link_to url, class: "text-dark text-decoration-none" do %>
                <span class="text-danger me-2">&rarr;</span><%= label %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Contact column -->
      <div class="col-md-3 col-sm-6">
        <h4 class="fw-bold mb-4">Contact Now</h4>

        <p class="fw-bold mb-1">Address</p>
        <p class="mb-3">1640 El Greco Drive, El Monte, CA 91731</p>

        <p class="fw-bold mb-1">Mailing Address</p>
        <p class="mb-3">1640 El Greco Drive, El Monte, CA 91731</p>

        <p class="mb-3">+1 (626) 320-5412</p>

        <div class="d-flex gap-2">
          <a href="#" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-facebook"></i>
          </a>
          <a href="#" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
            <i class="bi bi-google"></i>
          </a>
        </div>
      </div>

    </div>
  </div>
</footer>
