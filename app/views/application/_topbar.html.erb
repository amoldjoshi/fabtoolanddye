<div class="bg-primary text-white border-bottom border-2" style="border-color: rgba(255,255,255,0.25) !important;">
  <div class="container-fluid d-flex justify-content-between align-items-center py-1">
    <span class="mb-0 fs-4">Brings Innovation to Shape!</span>

    <ul class="navbar-nav ms-auto me-3 flex-row">
      <% if user_signed_in? %>
        <li class="nav-item">
          <span class="nav-link disabled me-2"><%= current_user.email %></span>
        </li>
        <li class="nav-item">
          <span class="nav-link disabled me-2">
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn-secondary btn-sm" %>
          </span>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to "Sign up now!", new_user_registration_path, class: "nav-link me-2" %>
        </li>
        <li class="nav-item">
          <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
        </li>
      <% end %>
    </ul>

    <form class="d-flex">
      <input class="form-control form-control-sm me-sm-2" type="search" placeholder="Search">
      <button class="btn btn-secondary btn-sm my-2 my-sm-0" type="submit">Search</button>
    </form>
  </div>
</div>